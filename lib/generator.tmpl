test $test_id [testTitle $case] -body {
    [dict get $case property] [tclString [dict get $case input phrase]]
!   if {[dict exists $case expected error]} {
} -returnCodes error -result [dict get $case expected error]
!   } else {
} -returnCodes ok -result [dict get $case expected]
!   }

! }

$footer
