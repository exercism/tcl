!* variableSubst true
!* commandSubst true
$header

! set i 0
! foreach case $cases {
!   set test_id "${slug}-[incr i]"
!   if {$i > 1} {
skip $test_id
!   }
test $test_id [testTitle $case] -body {
    [dict get $case property] [asList [dict get $case input strings]]
} -returnCodes ok -match orderedList -result [asList [dict get $case expected] -strings y -multiline y -indent 1]

! }

$footer
