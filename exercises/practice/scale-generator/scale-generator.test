#!/usr/bin/env tclsh
# generated: 2026-07-24T01:23:56Z
package require tcltest
namespace import ::tcltest::*
source testHelpers.tcl

# Uncomment next line to view test durations.
#configure -verbose {body error usec}

############################################################
source "scale-generator.tcl"


test scale-generator-1 "Chromatic scales: Chromatic scale with sharps" -body {
    set scale [Scale new C]
    $scale chromatic
} -returnCodes ok -match orderedLists -result {
    C C# D D# E F F# G G# A A# B
}
skip scale-generator-2
test scale-generator-2 "Chromatic scales: Chromatic scale with flats" -body {
    set scale [Scale new F]
    $scale chromatic
} -returnCodes ok -match orderedLists -result {
    F Gb G Ab A Bb B C Db D Eb E
}
skip scale-generator-3
test scale-generator-3 "Scales with specified intervals: Simple major scale" -body {
    set scale [Scale new C]
    $scale intervals MMmMMMm
} -returnCodes ok -match orderedLists -result {
    C D E F G A B C
}
skip scale-generator-4
test scale-generator-4 "Scales with specified intervals: Major scale with sharps" -body {
    set scale [Scale new G]
    $scale intervals MMmMMMm
} -returnCodes ok -match orderedLists -result {
    G A B C D E F# G
}
skip scale-generator-5
test scale-generator-5 "Scales with specified intervals: Major scale with flats" -body {
    set scale [Scale new F]
    $scale intervals MMmMMMm
} -returnCodes ok -match orderedLists -result {
    F G A Bb C D E F
}
skip scale-generator-6
test scale-generator-6 "Scales with specified intervals: Minor scale with sharps" -body {
    set scale [Scale new f#]
    $scale intervals MmMMmMM
} -returnCodes ok -match orderedLists -result {
    F# G# A B C# D E F#
}
skip scale-generator-7
test scale-generator-7 "Scales with specified intervals: Minor scale with flats" -body {
    set scale [Scale new bb]
    $scale intervals MmMMmMM
} -returnCodes ok -match orderedLists -result {
    Bb C Db Eb F Gb Ab Bb
}
skip scale-generator-8
test scale-generator-8 "Scales with specified intervals: Dorian mode" -body {
    set scale [Scale new d]
    $scale intervals MmMMMmM
} -returnCodes ok -match orderedLists -result {
    D E F G A B C D
}
skip scale-generator-9
test scale-generator-9 "Scales with specified intervals: Mixolydian mode" -body {
    set scale [Scale new Eb]
    $scale intervals MMmMMmM
} -returnCodes ok -match orderedLists -result {
    Eb F G Ab Bb C Db Eb
}
skip scale-generator-10
test scale-generator-10 "Scales with specified intervals: Lydian mode" -body {
    set scale [Scale new a]
    $scale intervals MMMmMMm
} -returnCodes ok -match orderedLists -result {
    A B C# D# E F# G# A
}
skip scale-generator-11
test scale-generator-11 "Scales with specified intervals: Phrygian mode" -body {
    set scale [Scale new e]
    $scale intervals mMMMmMM
} -returnCodes ok -match orderedLists -result {
    E F G A B C D E
}
skip scale-generator-12
test scale-generator-12 "Scales with specified intervals: Locrian mode" -body {
    set scale [Scale new g]
    $scale intervals mMMmMMM
} -returnCodes ok -match orderedLists -result {
    G Ab Bb C Db Eb F G
}
skip scale-generator-13
test scale-generator-13 "Scales with specified intervals: Harmonic minor" -body {
    set scale [Scale new d]
    $scale intervals MmMMmAm
} -returnCodes ok -match orderedLists -result {
