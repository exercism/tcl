!* variableSubst true
!* commandSubst true
$header

! set i 0
! foreach case $cases {
!   set test_id "${slug}-[incr i]"
!   if {$i > 1} {
skip $test_id
!   }
test $test_id [testTitle $case] -body {
    triangle [dict get $case input count]
} -returnCodes ok -match orderedLists -result [asList [dict get $case expected] -lists y -multiline y -indent 1]

! }

$footer
