!* variableSubst true
!* commandSubst true
$header

! set i 0
! foreach case $cases {
!   set test_id "${slug}-[incr i]"
!   if {$i > 1} {
skip $test_id
!   }
!   set title [join [concat [lrange [dict get $case group] 1 end] [list [dict get $case description]]] :]
test $test_id [tclString $title] -body {
    abbreviate [tclString [dict get $case input phrase]]
} -returnCodes ok -result [dict get $case expected]

! }

$footer
