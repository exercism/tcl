!* variableSubst true
!* commandSubst true
$header

! set i 0
! foreach case $cases {
!   set test_id "${slug}-[incr i]"
!   if {$i > 1} {
skip $test_id
!   }
test $test_id [testTitle $case] -body {
    calculate [asList [dict get $case input texts] -strings y -multiline y -indent 2]
} -returnCodes ok -match dictionary -result [asList [dict get $case expected]]

! }

$footer
